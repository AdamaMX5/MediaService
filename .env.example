# Server
PORT=3000
BASE_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://mediaservice:mediaservice_password@mongodb:27017/mediadb

# Auth Service (used once on startup to fetch the JWT public key)
AUTH_SERVICE_URL=https://auth.freischule.info

# File storage – mount this path as a Docker volume
UPLOAD_DIR=/uploads

# File limits
# MAX_FILE_SIZE in bytes; set to 0 for unlimited (default)
MAX_FILE_SIZE=0
# Comma-separated MIME types; leave empty to allow all
# e.g. image/jpeg,image/png,image/webp,video/mp4
ALLOWED_MIME_TYPES=
